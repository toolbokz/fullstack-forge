# Database
DATABASE_URL="mongodb+srv://USER:PASSWORD@HOST/DATABASE"

# NextAuth
NEXTAUTH_URL="http://localhost:3000/"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── Stripe ──────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# Stripe Price IDs — create these in the Stripe Dashboard
# Website Optimisation tiers (one-time)
STRIPE_PRICE_OPTIMISATION_LITE="price_xxxxxxx"
STRIPE_PRICE_OPTIMISATION_PLUS="price_xxxxxxx"
STRIPE_PRICE_OPTIMISATION_PRO="price_xxxxxxx"
# SEO Setup tiers (one-time)
STRIPE_PRICE_SEO_BASIC="price_xxxxxxx"
STRIPE_PRICE_SEO_LOCAL="price_xxxxxxx"
STRIPE_PRICE_SEO_COMPLETE="price_xxxxxxx"
# Website Build (one-time deposit)
STRIPE_PRICE_WEBSITE_BUILD_DEPOSIT="price_xxxxxxx"
# Monthly SEO tiers (subscription)
STRIPE_PRICE_SEO_CARE="price_xxxxxxx"
STRIPE_PRICE_SEO_GROWTH="price_xxxxxxx"
STRIPE_PRICE_SEO_MOMENTUM="price_xxxxxxx"

# Email (Resend)
RESEND_API_KEY="re_your_resend_api_key"

# Media APIs
UNSPLASH_ACCESS_KEY="your-unsplash-key"
PIXABAY_API_KEY="your-pixabay-key"

# Google PageSpeed Insights
GOOGLE_PSI_API_KEY="your-google-psi-key"
